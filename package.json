{
  "name": "web-content",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public",
    "start": "next start",
    "start:prod": "bun .next/standalone/server.js",
    "pm2:start": "bunx --bun pm2 start ecosystem.config.cjs --env production",
    "pm2:restart": "bunx --bun pm2 restart arrayhash-com-next --update-env",
    "pm2:stop": "bunx --bun pm2 delete arrayhash-com-next",
    "pm2:logs": "bunx --bun pm2 logs arrayhash-com-next",
    "pm2:save": "bunx --bun pm2 save",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "next": "^16.2.3",
    "pm2": "^6.0.14",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.3",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.37.0",
    "eslint-config-next": "^16.2.3",
    "gray-matter": "^4.0.3",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sass": "^1.99.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}